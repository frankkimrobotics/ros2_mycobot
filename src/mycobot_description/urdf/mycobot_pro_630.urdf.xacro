<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mycobot_pro_630">

  <!-- Arguments -->
  <xacro:arg name="use_sim" default="false"/>
  <xacro:arg name="use_fake_hardware" default="true"/>

  <!-- ==================== Materials ==================== -->
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1"/>
  </material>

  <!-- ==================== Base Link ==================== -->
  <link name="base_link"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/base.dae"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/base.dae"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- ==================== Link 1 ==================== -->
  <link name="link1">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link1.dae"/>
      </geometry>
      <origin xyz="0 0 -0.06" rpy="0 0 3.1415926"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link1.dae"/>
      </geometry>
      <origin xyz="0 0 -0.06" rpy="0 0 3.1415926"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-3.14159" upper="3.14159" velocity="1.5"/>
    <parent link="base"/>
    <child link="link1"/>
    <origin xyz="0 0 0.22934" rpy="0 0 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== Link 2 ==================== -->
  <link name="link2">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link2.dae"/>
      </geometry>
      <origin xyz="0 0 -0.0446" rpy="0 -1.5707 -1.5707"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link2.dae"/>
      </geometry>
      <origin xyz="0 0 -0.0446" rpy="0 -1.5707 -1.5707"/>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0.135 0 0" rpy="0 0 0"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <axis xyz="0 0 -1"/>
    <limit effort="1000.0" lower="-3.14159" upper="3.14159" velocity="1.5"/>
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="1.5707 -1.5708 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== Link 3 ==================== -->
  <link name="link3">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link3.dae"/>
      </geometry>
      <origin xyz="0 0 -0.0444" rpy="0 1.5707 -1.5707"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link3.dae"/>
      </geometry>
      <origin xyz="0 0 -0.0444" rpy="0 1.5707 -1.5707"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0.1335 0 0" rpy="0 0 0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="joint3" type="revolute">
    <axis xyz="0 0 -1"/>
    <limit effort="1000.0" lower="-2.61" upper="2.618" velocity="1.5"/>
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0.27 0 0" rpy="0 0 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== Link 4 ==================== -->
  <link name="link4">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link4.dae"/>
      </geometry>
      <origin xyz="0 0 0.041" rpy="-1.5707 0 1.5707"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link4.dae"/>
      </geometry>
      <origin xyz="0 0 0.041" rpy="-1.5707 0 1.5707"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 -0.0475 0" rpy="0 0 0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="joint4" type="revolute">
    <axis xyz="0 0 -1"/>
    <limit effort="1000.0" lower="-2.9670" upper="2.9670" velocity="1.5"/>
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.267 0 -0.0745" rpy="0 0 1.5708"/>
    <dynamics damping="0.3" friction="0.1"/>
  </joint>

  <!-- ==================== Link 5 ==================== -->
  <link name="link5">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link5.dae"/>
      </geometry>
      <origin xyz="-0.043 0 0" rpy="0 -1.5707 3.1415926"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link5.dae"/>
      </geometry>
      <origin xyz="-0.043 0 0" rpy="0 -1.5707 3.1415926"/>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <origin xyz="-0.027 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint5" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.93" upper="2.9321" velocity="1.5"/>
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 -0.095 0.002" rpy="1.5707 -1.5707 0"/>
    <dynamics damping="0.3" friction="0.1"/>
  </joint>

  <!-- ==================== Link 6 (End Effector Flange) ==================== -->
  <link name="link6">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link6.dae"/>
      </geometry>
      <origin xyz="0.01 0 0" rpy="0 1.5707 0"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link6.dae"/>
      </geometry>
      <origin xyz="0.01 0 0" rpy="0 1.5707 0"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0.01 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="joint6" type="revolute">
    <axis xyz="-1 0 0"/>
    <limit effort="1000.0" lower="-3.03" upper="3.0368" velocity="1.5"/>
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="-0.054 0 0" rpy="-1.5707 0 0"/>
    <dynamics damping="0.2" friction="0.1"/>
  </joint>

  <!-- ==================== Suction Cup End Effector ==================== -->
  <link name="suction_cup">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/single_suction_cup.dae"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="suction_cup_joint" type="fixed">
    <parent link="link6"/>
    <child link="suction_cup"/>
    <origin xyz="0.02 0 0" rpy="0 1.5708 0"/>
  </joint>

  <!-- ==================== Tool Center Point (TCP) ==================== -->
  <link name="tcp">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="tcp_joint" type="fixed">
    <parent link="suction_cup"/>
    <child link="tcp"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ==================== ros2_control ==================== -->
  <ros2_control name="mycobot_system" type="system">
    <xacro:if value="$(arg use_fake_hardware)">
      <hardware>
        <plugin>mock_components/GenericSystem</plugin>
      </hardware>
    </xacro:if>
    <xacro:unless value="$(arg use_fake_hardware)">
      <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      </hardware>
    </xacro:unless>

    <joint name="joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint5">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint6">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Gazebo plugin for ros2_control -->
  <xacro:if value="$(arg use_sim)">
    <gazebo>
      <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
        <parameters>$(find mycobot_description)/config/controllers.yaml</parameters>
      </plugin>
    </gazebo>
  </xacro:if>

</robot>
