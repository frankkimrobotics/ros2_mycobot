<?xml version="1.0"?>
<robot name="mycobot_pro_630">

  <!-- ==================== Materials ==================== -->
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1"/>
  </material>

  <!-- ==================== Base Link ==================== -->
  <link name="base_link"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/base.dae"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/base.dae"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
    </collision>
    <inertial>
      <mass value="3.4225"/>
      <origin xyz="-0.01340 0.00001 0.06584" rpy="0 0 0"/>
      <inertia ixx="1.129165e-02" ixy="5.520573e-08" ixz="-1.427358e-04" iyy="1.123173e-02" iyz="-2.051531e-07" izz="9.902095e-03"/>
    </inertial>
  </link>

  <!-- ==================== Link 1 ==================== -->
  <link name="link1">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link1.dae"/>
      </geometry>
      <origin xyz="0 0 -0.06" rpy="0 0 3.1415926"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link1.dae"/>
      </geometry>
      <origin xyz="0 0 -0.06" rpy="0 0 3.1415926"/>
    </collision>
    <inertial>
      <mass value="0.5434"/>
      <origin xyz="0.00000 0.00756 -0.01455" rpy="0 0 0"/>
      <inertia ixx="5.668835e-04" ixy="-3.760352e-12" ixz="9.896184e-13" iyy="5.117732e-04" iyz="-4.413917e-05" izz="4.049449e-04"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-3.14159" upper="3.14159" velocity="1.5"/>
    <parent link="base"/>
    <child link="link1"/>
    <origin xyz="0 0 0.22934" rpy="0 0 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== Link 2 ==================== -->
  <link name="link2">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link2.dae"/>
      </geometry>
      <origin xyz="0 0 -0.0446" rpy="0 -1.5707 -1.5707"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link2.dae"/>
      </geometry>
      <origin xyz="0 0 -0.0446" rpy="0 -1.5707 -1.5707"/>
    </collision>
    <inertial>
      <mass value="1.8125"/>
      <origin xyz="0.13444 0.00002 -0.07533" rpy="0 0 0"/>
      <inertia ixx="1.228935e-03" ixy="-1.272130e-06" ixz="-2.471483e-08" iyy="1.586526e-02" iyz="-9.612172e-09" izz="1.590244e-02"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <axis xyz="0 0 -1"/>
    <limit effort="1000.0" lower="-3.14159" upper="3.14159" velocity="1.5"/>
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="1.5707 -1.5708 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== Link 3 ==================== -->
  <link name="link3">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link3.dae"/>
      </geometry>
      <origin xyz="0 0 -0.0444" rpy="0 1.5707 -1.5707"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link3.dae"/>
      </geometry>
      <origin xyz="0 0 -0.0444" rpy="0 1.5707 -1.5707"/>
    </collision>
    <inertial>
      <mass value="2.2651"/>
      <origin xyz="0.12248 -0.00023 0.00100" rpy="0 0 0"/>
      <inertia ixx="2.064878e-03" ixy="-1.732790e-06" ixz="-3.721500e-04" iyy="1.966886e-02" iyz="-9.829410e-08" izz="1.904045e-02"/>
    </inertial>
  </link>

  <joint name="joint3" type="revolute">
    <axis xyz="0 0 -1"/>
    <limit effort="1000.0" lower="-2.61" upper="2.618" velocity="1.5"/>
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0.27 0 0" rpy="0 0 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== Link 4 ==================== -->
  <link name="link4">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link4.dae"/>
      </geometry>
      <origin xyz="0 0 0.041" rpy="-1.5707 0 1.5707"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link4.dae"/>
      </geometry>
      <origin xyz="0 0 0.041" rpy="-1.5707 0 1.5707"/>
    </collision>
    <inertial>
      <mass value="0.3447"/>
      <origin xyz="-0.00000 -0.01491 0.00910" rpy="0 0 0"/>
      <inertia ixx="2.681047e-04" ixy="-2.278568e-08" ixz="4.082182e-09" iyy="1.881600e-04" iyz="-2.695459e-05" izz="2.437713e-04"/>
    </inertial>
  </link>

  <joint name="joint4" type="revolute">
    <axis xyz="0 0 -1"/>
    <limit effort="1000.0" lower="-2.9670" upper="2.9670" velocity="1.5"/>
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.267 0 -0.0745" rpy="0 0 1.5708"/>
    <dynamics damping="0.3" friction="0.1"/>
  </joint>

  <!-- ==================== Link 5 ==================== -->
  <link name="link5">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link5.dae"/>
      </geometry>
      <origin xyz="-0.043 0 0" rpy="0 -1.5707 3.1415926"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link5.dae"/>
      </geometry>
      <origin xyz="-0.043 0 0" rpy="0 -1.5707 3.1415926"/>
    </collision>
    <inertial>
      <mass value="0.4204"/>
      <origin xyz="0.00078 -0.00000 -0.00654" rpy="0 0 0"/>
      <inertia ixx="2.502357e-04" ixy="1.986448e-12" ixz="-2.156206e-06" iyy="3.887104e-04" iyz="-3.526369e-12" izz="3.525862e-04"/>
    </inertial>
  </link>

  <joint name="joint5" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.93" upper="2.9321" velocity="1.5"/>
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 -0.095 0.002" rpy="1.5707 -1.5707 0"/>
    <dynamics damping="0.3" friction="0.1"/>
  </joint>

  <!-- ==================== Link 6 (End Effector Flange) ==================== -->
  <link name="link6">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link6.dae"/>
      </geometry>
      <origin xyz="0.01 0 0" rpy="0 1.5707 0"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/link6.dae"/>
      </geometry>
      <origin xyz="0.01 0 0" rpy="0 1.5707 0"/>
    </collision>
    <inertial>
      <mass value="0.0376"/>
      <origin xyz="0.00543 0.00000 -0.00000" rpy="0 0 0"/>
      <inertia ixx="1.679697e-05" ixy="-1.012847e-13" ixz="8.043638e-10" iyy="8.708365e-06" iyz="6.140298e-13" izz="8.708534e-06"/>
    </inertial>
  </link>

  <joint name="joint6" type="revolute">
    <axis xyz="-1 0 0"/>
    <limit effort="1000.0" lower="-3.03" upper="3.0368" velocity="1.5"/>
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="-0.054 0 0" rpy="-1.5707 0 0"/>
    <dynamics damping="0.2" friction="0.1"/>
  </joint>

  <!-- ============ Camera Wrist Mount (D405 eye-in-hand bracket) ============ -->
  <!-- The pro630 ring (r=30mm) bolts flat on the link6 flange face; the arm + D405 case
       extend toward link6 -Y (the eye-in-hand camera side). STL is mm (scale 0.001).
       Pose: STL +Z -> flange axis (link6 X), STL +Y -> link6 -Y; ring centre at flange. -->
  <link name="camera_mount">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/d405_case_ring_offset70_tilt10_arm.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/d405_case_ring_offset70_tilt10_arm.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="3e-05" ixy="0" ixz="0" iyy="3e-05" iyz="0" izz="3e-05"/>
    </inertial>
  </link>
  <joint name="camera_mount_joint" type="fixed">
    <parent link="link6"/>
    <child link="camera_mount"/>
    <origin xyz="-0.003 -0.003 0" rpy="3.1416 1.5708 0"/>
  </joint>

  <!-- ==================== Suction Cup End Effector ==================== -->
  <link name="suction_cup">
    <visual>
      <geometry>
        <mesh filename="package://mycobot_description/meshes/single_suction_cup.dae" />
      </geometry>
      <!-- DAE Z-up, unit=0.001 (mm); bounding box centroid at origin.
           Shifted -6mm along the tool axis (suction_cup -Z) so the cup body sits BELOW the
           camera wrist-mount ring instead of overlapping it (cup screws into the mount). -->
      <origin xyz="0 0 -0.0585" rpy="1.5708 0 0"/>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.06"/>
      </geometry>
      <origin xyz="0. 0 -0.006" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.1537"/>
      <origin xyz="0.00000 -0.00000 -0.03428" rpy="0 0 0"/>
      <inertia ixx="1.215946e-04" ixy="2.031805e-13" ixz="-3.218520e-13" iyy="1.215946e-04" iyz="3.146202e-10" izz="3.597206e-05"/>
    </inertial>
  </link>

  <joint name="suction_cup_joint" type="fixed">
    <parent link="link6"/>
    <child link="suction_cup"/>
    <!-- Mounted at flange; suction_cup +Z aligned with link6 +X (tool axis) -->
    <origin xyz="0 0 0" rpy="0 1.5708 0"/>
  </joint>

  <!-- ==================== Tool Center Point (TCP) ==================== -->
  <link name="tcp">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="tcp_joint" type="fixed">
    <parent link="suction_cup"/>
    <child link="tcp"/>
    <!-- TCP = real suction-cup tip along suction_cup +Z (= link6 -X), rpy 3.1416
         (RotX 180) so tcp +Z = approach axis points DOWN.
         Length 0.135 m. RE-CALIBRATED 2026-06-30 by a J2-shoulder-torque floor touch-test
         (calib_z.py, base on the table so base_link z=0 == table): with the prior tcp=0.145
         the cup only first-touched the table when the MODEL put the tip at z ~ -0.010 m,
         i.e. the suction cup had shortened ~10 mm (compression set from repeated presses)
         since the 2026-06-27 calibration below. That 10 mm made every touch/grasp land high
         and miss objects. New tip length = 0.145 - 0.010 = 0.135 m.
         PRIOR (2026-06-27): tcp=0.13 -> cup touched at MODEL z~0.0158 -> real tip 0.145 m
         below flange (0.13 + 0.0158); matched hand-eye T_tcp_cam (config.CAM_TCP_Z_SHIFT=0). -->
    <origin xyz="0 0 -0.135" rpy="3.1416 0 0"/>
  </joint>

  <!-- ==================== End Effector Frame (EEF) ==================== -->
  <link name="eef">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="eef_joint" type="fixed">
    <parent link="suction_cup"/>
    <child link="eef"/>
    <origin xyz="0 0 -0.105" rpy="3.1416 0 0"/>
  </joint>

</robot>
